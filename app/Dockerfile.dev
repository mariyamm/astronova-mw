FROM python:3.11-slim

# Labels for metadata
LABEL maintainer="AstroNova Team"
LABEL version="1.0.0-dev"
LABEL description="AstroNova - Astrology Analysis Platform (Development)"

# Set environment variables for development
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    PORT=8000 \
    DEBUG=True

# Install system dependencies required by WeasyPrint (PDF rendering) + Cyrillic font support
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpango-1.0-0 \
    libpangocairo-1.0-0 \
    libgdk-pixbuf-xlib-2.0-0 \
    libcairo2 \
    libffi-dev \
    libglib2.0-0 \
    shared-mime-info \
    fonts-liberation \
    fonts-dejavu-core \
    fonts-noto \
    fontconfig \
    curl \
    git \
    && fc-cache -fv \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /app

# Install Python dependencies (including development dependencies)
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt && \
    pip install --no-cache-dir watchfiles python-dotenv

# Create necessary directories
RUN mkdir -p /app/pdf_output /app/static /app/logs

# Copy application code (will be overridden by volume in development)
COPY . .

# Health check (less frequent for development)
HEALTHCHECK --interval=60s --timeout=30s --start-period=10s --retries=2 \
    CMD curl -f http://localhost:${PORT}/api/admin/health || exit 1

# Expose port
EXPOSE ${PORT}

# Development command with auto-reload
CMD ["sh", "-c", "uvicorn main:app --host 0.0.0.0 --port $PORT --reload --reload-dir /app --log-level debug"]