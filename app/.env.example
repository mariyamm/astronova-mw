# =============================================================================
# AstroNova Application Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# Application Configuration
APP_NAME=AstroNova Admin
APP_VERSION=1.0.0
DEBUG=True
PORT=8000

# Security Configuration
# IMPORTANT: Generate a strong, random secret key for production!
# You can use: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-this-in-production-make-it-very-long-and-random
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/astronova
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=astronova

# Redis Configuration (for Celery task queue)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# CORS Configuration (comma-separated origins)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8000

# =============================================================================
# External API Configuration
# =============================================================================

# OpenAI Configuration (required for GPT report generation)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Shopify Configuration (required for order sync)
SHOPIFY_SHOP_URL=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your-shopify-admin-api-access-token
SHOPIFY_API_VERSION=2024-01
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret

# TimeZone DB Configuration (for timezone calculations)
TIMEZONEDB_API_KEY=your-timezonedb-api-key

# =============================================================================
# Google Drive Integration (for PDF storage)
# =============================================================================

# Google Drive Folder Name (folder will be created if it doesn't exist)
GDRIVE_FOLDER_NAME=AstroNova PDFs

# Google Drive OAuth Credentials (JSON content as single line)
# Get from Google Cloud Console > APIs & Services > Credentials
GDRIVE_CLIENT_JSON={"web":{"client_id":"your-client-id","client_secret":"your-client-secret","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","redirect_uris":["http://localhost:8000/gdrive-callback"]}}

# Google Drive OAuth Token (generated after first authorization)
# This will be auto-generated when you first authorize the app
GDRIVE_TOKEN_JSON={"token":"your-access-token","refresh_token":"your-refresh-token","token_uri":"https://oauth2.googleapis.com/token","client_id":"your-client-id","client_secret":"your-client-secret","scopes":["https://www.googleapis.com/auth/drive.file"]}

# =============================================================================
# Production Configuration (for docker-compose.prod.yml)
# =============================================================================

# Production Database (use strong passwords!)
POSTGRES_PASSWORD_PROD=your-very-strong-production-password

# Production Redis (use strong passwords!)
REDIS_PASSWORD_PROD=your-redis-password

# Production App Port
APP_PORT=8000

# Email Configuration (optional, for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
